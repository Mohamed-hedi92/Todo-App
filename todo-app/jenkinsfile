pipeline {
    agent any

    tools {
        maven 'maven'
        nodejs 'nodejs'
    }

    environment {
        CI = 'true'
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                    credentialsId: 'gitlab-credentials-id',
                    url: 'https://gitlab.isoad.isogmbh.de/ata/junit.git'
            }
        }

        stage('Backend Build') {
            steps {
                echo 'Building the backend...'
                dir('todo-app') {
                    bat 'mvn clean install'
                }
            }
        }

        stage('Backend Unit Tests') {
            steps {
                echo 'Running backend unit tests...'
                dir('todo-app') {
                    bat 'mvn test'
                }
            }
        }

        stage('Frontend Install') {
            steps {
                echo 'Installing frontend dependencies...'
                dir('todo-app/todo-frontend') {
                    bat 'npm install'
                }
            }
        }

        stage('Verify Tests Exist') {
            steps {
                dir('todo-app/todo-frontend/src') {
                    bat 'dir /B'
                }
            }
        }


        stage('Frontend Jest Unit Tests') {
            steps {
                echo 'Running frontend Jest tests...'
                dir('todo-app/todo-frontend') {
                    bat 'npm test'
                }
            }
        }

        stage('Start Backend') {
            steps {
                echo 'Starting backend for Playwright tests...'
                dir('todo-app') {
                    bat 'start /B mvn spring-boot:run'
                }
                sleep time: 10, unit: 'SECONDS'
            }
        }

        stage('Playwright E2E Tests') {
            steps {
                echo 'Running Playwright end-to-end tests...'
                dir('todo-app/todo-frontend') {
                    bat 'npx playwright install'
                    bat 'npx playwright test'
                }
            }
        }

        stage('Frontend Build') {
            steps {
                echo 'Building the frontend...'
                dir('todo-app/todo-frontend') {
                    bat 'npm run build'
                }
            }
        }
    }

    post {
        success {
            echo 'Build and all tests completed successfully.'
        }
        failure {
            echo 'Build or tests failed. Please check logs.'
        }
    }
}
