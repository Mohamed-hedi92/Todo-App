pipeline {
    agent any

    tools {
        maven 'maven'
        nodejs 'nodejs'
    }

    environment {
        CI = 'true'
    }

    stages {
        stage('Clean Workspace') {
            steps {
                echo '🧹 Cleaning Jenkins workspace'
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
                echo '=== Checking out Git Repository ==='
                git branch: 'feature/openapi-clean',
                    credentialsId: 'gitlab-credentials-id',
                    url: 'https://gitlab.isoad.isogmbh.de/ata/junit.git'

                echo ' Forcing clean Git working directory'
                bat 'git clean -fdx'
            }
        }

        stage('Backend Build') {
            steps {
                echo '=== Building the Backend ==='
                dir('todo-app') {
                    bat 'mvn clean install'
                }
            }
        }

        stage('Backend Unit Tests') {
            steps {
                echo '=== Running Backend Unit Tests ==='
                dir('todo-app') {
                    bat 'mvn test'
                }
            }
        }

        stage('Frontend Install') {
            steps {
                echo '=== Installing Frontend Dependencies ==='
                dir('todo-app/todo-frontend') {
                    bat 'node -v'
                    bat 'npm -v'
                    bat 'npm cache clean --force'
                    bat 'if exist node_modules (echo node_modules existiert && rmdir /s /q node_modules) else (echo node_modules existiert NICHT)'
                    bat 'npm install'
                }
            }
        }

        stage('Debug Config Files') {
            steps {
                echo '=== Showing jest.config.js and package.json ==='
                dir('todo-app/todo-frontend') {
                    bat 'type jest.config.js'
                    bat 'type package.json'
                }
            }
        }

        stage('Frontend Jest Unit Tests') {
            steps {
                echo '=== Running Frontend Jest Unit Tests ==='
                dir('todo-app/todo-frontend') {
                    // npm test nutzt in package.json jetzt: jest --testPathIgnorePatterns="e2e" --passWithNoTests
                    bat 'npm test'
                }
            }
        }

        stage('Start Backend') {
            steps {
                echo '=== Starting Backend for E2E Tests ==='
                dir('todo-app') {
                    bat 'start /B mvn spring-boot:run'
                }
                // Wartezeit für Backend, ggf. anpassen
                sleep time: 15, unit: 'SECONDS'
            }
        }

        stage('Playwright E2E Tests') {
            steps {
                echo '=== Running Playwright End-to-End Tests ==='
                dir('todo-app/todo-frontend') {
                    bat 'npx playwright install'
                    bat 'npm run test:e2e'
                }
            }
        }

        stage('Frontend Build') {
            steps {
                echo '=== Building the Frontend ==='
                dir('todo-app/todo-frontend') {
                    bat 'npm run build'
                }
            }
        }
    }

    post {
        success {
            echo '✅ Build and all tests completed successfully.'
        }
        failure {
            echo '❌ Build or tests failed. Please check the logs above.'
        }
    }
}
