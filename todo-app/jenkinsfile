pipeline {
    agent any

    tools {
        maven 'maven'
        nodejs 'nodejs'
    }

    environment {
        CI = 'true'
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                    credentialsId: 'gitlab-credentials-id',
                    url: 'https://gitlab.isoad.isogmbh.de/ata/junit.git'
            }
        }

        stage('Backend Build') {
            steps {
                echo 'Building the backend...'
                dir('todo-app') {
                    bat 'mvn clean install'
                }
            }
        }

        stage('Backend Test') {
            steps {
                echo 'Running backend tests...'
                dir('todo-app') {
                    bat 'mvn test'
                }
            }
        }

        stage('Frontend Install') {
            steps {
                echo 'Installing frontend dependencies...'
                dir('todo-app/todo-frontend') {
                    bat 'npm install'
                }
            }
        }

        stage('Frontend Test') {
            steps {
                echo 'Running frontend tests...'
                dir('todo-app/todo-frontend') {
                    bat 'set CI=true && npm test -- --watchAll=false --passWithNoTests'

                }
            }
        }

        stage('Frontend Build') {
            steps {
                echo 'Building the frontend...'
                dir('todo-app/todo-frontend') {
                    bat 'npm run build'
                }
            }
        }
    }

    post {
        success {
            echo 'Build and tests for backend and frontend completed successfully.'
        }
        failure {
            echo 'Build failed. Please check logs.'
        }
    }
}
